# Copy this file to `.env` for local development and fill in real values.
# On Render, set these as environment variables in the dashboard instead.

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use a local SQLite file (zero setup).
# For Neon Postgres, paste your connection string and change the scheme to
# postgresql+psycopg, e.g.:
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
# DATABASE_URL=sqlite:///./smart_sprint.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong one with:  openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Google SSO (optional) ─────────────────────────────────────────────────────
# OAuth 2.0 *Web* client ID from Google Cloud Console. Leave blank to disable.
# GOOGLE_CLIENT_ID=1234567890-abcdef.apps.googleusercontent.com

# ── App URL (for invite links) ────────────────────────────────────────────────
# Public URL of your Flutter web frontend. Invite accept links are built as
# {APP_BASE_URL}/#/invite/{token}. Set this to your deployed web app's origin.
APP_BASE_URL=http://localhost:8080

# ── Email / SMTP (invitations) ────────────────────────────────────────────────
# Leave SMTP_HOST blank to DISABLE real email — invites are still created and
# the accept link is returned by the API so the flow works without a provider.
# To send real emails (e.g. Gmail): create an App Password and fill these in.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=you@gmail.com          # optional, defaults to SMTP_USER
#   SMTP_USE_TLS=true                # true=STARTTLS/587, false=SSL/465
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. "*" is fine here (we use Bearer tokens).
# In production you can lock it to your web app's domain.
CORS_ORIGINS=*

ENVIRONMENT=development
