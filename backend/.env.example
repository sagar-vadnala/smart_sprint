# Copy this file to `.env` for local development and fill in real values.
# On Render, set these as environment variables in the dashboard instead.

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use a local SQLite file (zero setup).
# For Neon Postgres, paste your connection string and change the scheme to
# postgresql+psycopg, e.g.:
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
# DATABASE_URL=sqlite:///./smart_sprint.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong one with:  openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Google SSO (optional) ─────────────────────────────────────────────────────
# OAuth 2.0 *Web* client ID from Google Cloud Console. Leave blank to disable.
# GOOGLE_CLIENT_ID=1234567890-abcdef.apps.googleusercontent.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. "*" is fine here (we use Bearer tokens).
# In production you can lock it to your web app's domain.
CORS_ORIGINS=*

ENVIRONMENT=development
